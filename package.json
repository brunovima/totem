{
    "name":  "totem-app",
    "productName":  "TOTEM",
    "version":  "1.2.0",
    "description":  "An Electron application with React",
    "main":  "./out/main/index.js",
    "author":  "example.com",
    "homepage":  "https://electron-vite.org",
    "scripts":  {
                    "format":  "prettier --write .",
                    "lint":  "eslint --cache .",
                    "start":  "electron-vite preview",
                    "dev":  "electron-vite dev",
                    "build":  "electron-vite build",
                    "postinstall":  "electron-builder install-app-deps",
                    "build:unpack":  "npm run build \u0026\u0026 electron-builder --dir",
                    "build:win":  "npm run build \u0026\u0026 electron-builder --win",
                    "build:mac":  "npm run build \u0026\u0026 electron-builder --mac",
                    "build:linux":  "npm run build \u0026\u0026 electron-builder --linux",
                    "release":  "npm run build \u0026\u0026 electron-builder",
                    "pretest":  "npm rebuild better-sqlite3 --update-binary 2\u003e/dev/null || npm rebuild better-sqlite3",
                    "test":  "npx vitest run",
                    "posttest":  "node_modules/.bin/electron-rebuild -f -w better-sqlite3 2\u003e/dev/null || true",
                    "test:watch":  "npx vitest",
                    "test:db":  "npx vitest run tests/integration/database.test.js",
                    "test:tools":  "npx vitest run tests/integration/tools.test.js",
                    "pretest:e2e":  "node_modules/.bin/electron-rebuild -f -w better-sqlite3 2\u003e/dev/null || true",
                    "test:e2e":  "npx playwright test",
                    "test:e2e:ui":  "npx playwright test --ui",
                    "release:mac":  "bash scripts/package_release.sh mac",
                    "release:linux":  "bash scripts/package_release.sh linux",
                    "release:win":  "scripts\\package_release.bat",
                    "kit:win":  "scripts\\gerar_kit_operador.bat",
                    "setup:win":  "scripts\\instalar_build_tools.bat",
                    "start:container":  "electron --no-sandbox out/main/index.js",
                    "sync":  "bash scripts/sync_github.sh",
                    "security:check":  "semgrep --config=p/owasp-top-ten . --json",
                    "security:audit":  "npm audit \u0026\u0026 snyk test || true"
                },
    "dependencies":  {
                         "@electron-toolkit/preload":  "^3.0.2",
                         "@electron-toolkit/utils":  "^4.0.0",
                         "better-sqlite3":  "^12.9.0",
                         "express":  "^5.2.1",
                         "lucide-react":  "^1.8.0",
                         "qrcode.react":  "^4.2.0",
                         "react-player":  "^3.4.0",
                         "sharp":  "^0.34.5"
                     },
    "devDependencies":  {
                            "@electron-toolkit/eslint-config":  "^2.1.0",
                            "@electron-toolkit/eslint-config-prettier":  "^3.0.0",
                            "@playwright/test":  "^1.49.0",
                            "@vitejs/plugin-react":  "^5.1.1",
                            "electron":  "^39.8.9",
                            "electron-builder":  "^26.0.12",
                            "electron-rebuild":  "^3.2.9",
                            "electron-vite":  "^5.0.0",
                            "eslint":  "^9.39.1",
                            "eslint-plugin-react":  "^7.37.5",
                            "eslint-plugin-react-hooks":  "^7.1.1",
                            "eslint-plugin-react-refresh":  "^0.4.24",
                            "husky":  "^9.1.7",
                            "lint-staged":  "^16.4.0",
                            "prettier":  "^3.8.3",
                            "react":  "^19.2.1",
                            "react-dom":  "^19.2.1",
                            "vite":  "^7.2.6",
                            "vitest":  "^2.1.0"
                        }
}
